geometry_msgs/PoseStamped[] target_poses
# After this duration, the command will time out and the robot will stop. Must be non-zero
builtin_interfaces/Duration[] target_durations
# Provide transform from GRAVITY-ALIGNED body frame to task frame in which end-effector positions are specified
geometry_msgs/Transform body_to_task_frame
# If using impedance control, specify stiffness. Usual is [300, 300, 300, 60, 60, 60]
float64[] impedance_stiffness_diagonal
# If using impedance control, specify damping. Usual is [2.5, 2.5, 2.5, 1.0, 1.0, 1.0]
float64[] impedance_damping_diagonal
# Impedance = 0, Position = 1
int8 control
# If true, the feedback from the trajectory command must indicate that the robot is
# at the goal position. If set to false, the robot being near the goal is equivalent to
# it being at the goal. This is based on the feedback received from the boston dynamics
# API call at
# https://dev.bostondynamics.com/protos/bosdyn/api/proto_reference.html?highlight=status_near_goal#se2trajectorycommand-feedback-status
bool precise_positioning
# If true, turns off the vision body obstacle avoidance in mobility params
bool disable_obstacle_avoidance false
---
bool success
string message
---
string feedback
